# Easiest: don't edit this by hand. Run:  python -m triad setup
# (masked prompts, live key validation, writes .env with 600 perms + gitignores it)
#
# This file just documents the variable names. Copy to .env if you prefer manual setup.

# --- The three agents ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# --- Optional free-cloud providers (python -m triad setup --all) ---
# NVIDIA_NIM_API_KEY=nvapi-...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-...

# Model IDs change often — set whatever you actually want to run.
TRIAD_OPENAI_MODEL=gpt-4.1
TRIAD_CLAUDE_MODEL=claude-sonnet-4-6
TRIAD_GEMINI_MODEL=gemini-2.5-pro

# Optional
TRIAD_MAX_TOKENS=4096
